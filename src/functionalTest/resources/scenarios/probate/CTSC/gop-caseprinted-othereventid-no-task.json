              "replacements": {
                "EventId": "otherEventId",
                "NewStateId": "CasePrinted",
                "AdditionalData": {
                  "Data": {
                    "evidenceHandled": false,
                    "caseType": "gop",
                    "boHandoffReasonList": []
                  }
                }
              }
            }
          ]
        }
      },
      "expectations": [
        {
          "credentials": {
            "key": "CTSC-Administrator"
          },
          "status": 200,
          "numberOfTasksAvailable": 0
        }
      ]
    }
  ]
