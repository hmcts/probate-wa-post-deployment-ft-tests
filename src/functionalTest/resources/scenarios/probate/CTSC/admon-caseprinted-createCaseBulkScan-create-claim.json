{
  "description": "Create case for admonWill caseType with event createCaseFromBulkScan and CLAIM task",
  "enabled": true,
  "jurisdiction": "PROBATE",
  "caseType": "GrantOfRepresentation",
  "options": {
    "taskRetrievalApi": "task-management-api"
  },
  "required": {
    "credentials": {
      "key": "systemupdate"
    },
    "ccd": [
      {
        "eventId": "createCaseFromBulkScan",
        "caseData": {
          "template": "minimal-probate.json",
          "replacements": {
            "caseType": "admonWill"
          }
        }
      }
    ]
  },
  "tests": [
    {
      "request": {
        "credentials": {
          "key": "caseworker"
        },
        "input": {
          "eventMessages": [
            {
              "destination": "RestEndpoint",
              "template": "minimal-ccd-event-message-probate.json",
              "replacements": {
              }
            }
          ]
        }
      },
      "expectations": [
        {
          "credentials": {
            "key": "CTSC-Administrator"
          },
          "status": 200,
          "numberOfTasksAvailable": 1,
          "taskData": {
            "template": "minimal-task-response-probate.json",
            "replacements": {
              "tasks": [
                {
                  "task_state": "unassigned",
                  "type": "ExamineDigitalCaseAdmonWill",
                  "name": "Examine Digital Case - Admon"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "request": {
        "type": "CLAIM",
        "credentials": {
          "key": "team-leader",
          "granularPermission": true
        }
      },
      "expectations": [
        {
          "credentials": {
            "key": "CTSC-Administrator",
            "granularPermission": true
          },
          "status": 200,
          "numberOfTasksAvailable": 1,
          "taskData": {
            "template": "minimal-task-response-probate.json",
            "replacements": {
              "tasks": [
                {
                  "task_state": "assigned",
                  "assignee": "{$ASSIGNEE_ID}",
                  "type": "ExamineDigitalCaseAdmonWill",
                  "name": "Examine Digital Case - Admon"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
