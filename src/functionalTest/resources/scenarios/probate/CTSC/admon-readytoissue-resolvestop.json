{
  "description": "Create case with admonWill type in CasePrinted state, complete this task, then verify resolvestop in BOReadyToIssue state creates task for ExamineDigitalCaseAdmonWill",
  "enabled": true,
  "jurisdiction": "PROBATE",
  "caseType": "GrantOfRepresentation",
  "options": {
    "taskRetrievalApi": "task-management-api"
  },
  "required": {
    "credentials": {
      "key": "systemupdate"
    },
    "ccd": [
      {
        "eventId": "applyforGrantPaperApplicationMan",
        "caseData": {
          "template": "minimal-probate.json",
          "replacements": {
            "caseType": "admonWill"
          }
        }
      }
    ]
  },
  "before": {
    "request": {
      "credentials": {
        "key": "caseworker"
      },
      "input": {
        "eventMessages": [
          {
            "destination": "RestEndpoint",
            "template": "minimal-ccd-event-message-probate.json",
            "replacements": {
            }
          }
        ]
      }
    },
    "expectations": [
      {
        "credentials": {
          "key": "CTSC-Administrator"
        },
        "status": 200,
        "numberOfTasksAvailable": 1,
        "taskData": {
          "template": "minimal-task-response-probate.json",
          "replacements": {
            "tasks": [
              {
                "task_state": "unassigned",
                "type": "ExamineDigitalCaseAdmonWill",
                "name": "Examine Digital Case - Admon"
              }
            ]
          }
        }
      }
    ]
  },
  "tests": [
    {
      "request": {
        "type": "COMPLETE",
        "credentials": {
          "key": "team-leader",
            "granularPermission": true
          }
      },
      "expectations": [
        {
          "credentials": {
            "key": "CTSC-Administrator",
            "granularPermission": true
          },
          "status": 200,
          "numberOfTasksAvailable": 0
        }
      ]
    },
    {
      "request": {
        "credentials": {
          "key": "caseworker"
        },
        "input": {
          "eventMessages": [
            {
              "destination": "RestEndpoint",
              "template": "minimal-ccd-event-message-probate.json",
              "replacements": {
                "EventId": "boResolveStop",
                "NewStateId": "BOReadyToIssue",
                "AdditionalData": {
                  "Data": {
                    "evidenceHandled": false,
                    "caseType": "admonWill",
                    "boHandoffReasonList": []
                  }
                }
              }
            }
          ]
        }
      },
      "expectations": [
        {
          "credentials": {
            "key": "CTSC-Administrator",
            "granularPermission": true
          },
          "status": 200,
          "numberOfTasksAvailable": 1,
          "taskData": {
            "template": "minimal-task-response-probate.json",
            "replacements": {
              "tasks": [
                {
                  "task_state": "unassigned",
                  "type": "ExamineDigitalCaseAdmonWillReadyToIssue",
                  "name": "Examine Digital Case - Admon"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
