{
  "description": "CasePrinted handleEvidence CLAIM COMPLETE",
  "enabled": true,
  "jurisdiction": "PROBATE",
  "caseType": "GrantOfRepresentation",
  "options": {
    "taskRetrievalApi": "task-management-api"
  },
  "required": {
    "credentials": {
      "key": "systemupdate"
    },
    "ccd": [
      {
        "eventId": "applyforGrantPaperApplicationMan",
        "caseData": {
          "template": "minimal-probate.json",
          "replacements": {
          }
        }
      }
    ]
  },
  "before": {
    "request": {
      "credentials": {
        "key": "caseworker"
      },
      "input": {
        "eventMessages": [
          {
            "destination": "RestEndpoint",
            "template": "minimal-ccd-event-message-probate.json",
            "replacements": {
              "EventId": "handleEvidence",
              "NewStateId": "CasePrinted",
              "AdditionalData": {
                "Data": {
                  "evidenceHandled": false,
                  "caseType": "gop"
                }
              }
            }
          }
        ]
      }
    },
    "expectations": [
      {
        "credentials": {
          "key": "CTSC-Administrator"
        },
        "status": 200,
        "numberOfTasksAvailable": 1,
        "taskData": {
          "template": "minimal-task-response-probate.json",
          "replacements": {
            "tasks": [
              {
                "task_state": "unassigned",
                "task_system": "SELF",
                "test_meta_data": [
                  {
                    "key": "role_data_reference",
                    "value": "ExamineDigitalCaseProbate"
                  }
                ],
                "type": "ExamineDigitalCaseProbate",
                "name": "Examine Digital Case - Probate",
                "minor_priority": 500,
                "major_priority": 5000,
                "description": "[Amend Case Details](/cases/case-details/${[CASE_REFERENCE]}/trigger/boAmendCaseDetails)  [Issue Grant](/cases/case-details/${[CASE_REFERENCE]}/trigger/boIssueGrantForCaseMatching)  [Escalate to Registrar](/cases/case-details/${[CASE_REFERENCE]}/trigger/boEscalateToRegistrar)  [Select For QA](/cases/case-details/${[CASE_REFERENCE]}/trigger/boSelectForQA)  [SME Referral](/cases/case-details/${[CASE_REFERENCE]}/trigger/boUploadDocsForSMEReferral)  [Stop Case](/cases/case-details/${[CASE_REFERENCE]}/trigger/boStopCaseForCasePrinted)"
              }
            ]
          }
        },
        "roleData": [
          {
            "key": "ExamineDigitalCaseProbate",
            "numberOfRolesAvailable": 2,
            "roles": [
              {
                "role_category": "CTSC",
                "role_name": "ctsc",
                "permissions": [ "Read", "Own", "Claim", "Unclaim", "Assign", "Unassign" ],
                "authorisations": [ "SKILL:ABA6:ProbateExamining" ]
              },
              {
                "role_category": "CTSC",
                "role_name": "ctsc-team-leader",
                "permissions": [ "Read", "Own", "Claim", "Unclaim", "Manage", "Complete", "Cancel", "Assign", "Unassign" ],
                "authorisations": []
              }
            ]
          }
        ]
      }
    ]
  },
  "tests": [
    {
    "request": {
      "type": "CLAIM",
      "credentials": {
        "key": "team-leader",
        "granularPermission": true
      }
    },
    "expectations": [
      {
        "credentials": {
          "key": "CTSC-Administrator",
          "granularPermission": true
        },
        "status": 200,
        "numberOfTasksAvailable": 1,
        "taskData": {
          "template": "minimal-task-response-probate.json",
          "replacements": {
            "tasks": [
              {
                "task_state": "assigned",
                "task_system": "SELF",
                "test_meta_data": [
                  {
                    "key": "role_data_reference",
                    "value": "ExamineDigitalCaseProbate"
                  }
                ],
                "type": "ExamineDigitalCaseProbate",
                "name": "Examine Digital Case - Probate",
                "minor_priority": 500,
                "major_priority": 5000,
                "description": "[Amend Case Details](/cases/case-details/${[CASE_REFERENCE]}/trigger/boAmendCaseDetails)  [Issue Grant](/cases/case-details/${[CASE_REFERENCE]}/trigger/boIssueGrantForCaseMatching)  [Escalate to Registrar](/cases/case-details/${[CASE_REFERENCE]}/trigger/boEscalateToRegistrar)  [Select For QA](/cases/case-details/${[CASE_REFERENCE]}/trigger/boSelectForQA)  [SME Referral](/cases/case-details/${[CASE_REFERENCE]}/trigger/boUploadDocsForSMEReferral)  [Stop Case](/cases/case-details/${[CASE_REFERENCE]}/trigger/boStopCaseForCasePrinted)"
              }
            ]
          }
        }
      }
    ]
  },
    {
      "request": {
        "type": "COMPLETE",
        "credentials": {
          "key": "team-leader",
          "granularPermission": true
        }
      },
      "expectations": [
        {
          "credentials": {
            "key": "CTSC-Administrator",
            "granularPermission": true
          },
          "status": 200,
          "numberOfTasksAvailable": 0
        }
      ]
    }
  ]
}
